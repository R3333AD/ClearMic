<Window x:Class="ClearMic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClearMic"
        Width="400" Height="400"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ClearMic" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Grid.Row="0" />

        <ToggleButton x:Name="ToggleButton"
                      Grid.Row="1"
                      Margin="0,20"
                      Width="120" Height="40"
                      FontSize="16"
                      Checked="OnToggleChecked"
                      Unchecked="OnToggleUnchecked">
            Démarrer
        </ToggleButton>

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   HorizontalAlignment="Center"
                   FontSize="14"
                   Text="Prêt — VB-Cable requis" />

        <StackPanel Grid.Row="3" Margin="0,10">
            <TextBlock Text="Niveau entrée" FontSize="10" Foreground="#a6adc8" Margin="0,0,0,2" />
            <Border Height="16" BorderBrush="#45475a" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <ProgressBar x:Name="InputLevelBar"
                                 Minimum="0" Maximum="1" Value="0"
                                 Foreground="#f9e2af" Background="#313244" BorderThickness="0" />
                    <TextBlock x:Name="InputLevelText"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="9" Foreground="#cdd6f4" Text="— dB" />
                </Grid>
            </Border>

            <TextBlock Text="Niveau sortie" FontSize="10" Foreground="#a6adc8" Margin="0,6,0,2" />
            <Border Height="16" BorderBrush="#45475a" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <ProgressBar x:Name="OutputLevelBar"
                                 Minimum="0" Maximum="1" Value="0"
                                 Foreground="#a6e3a1" Background="#313244" BorderThickness="0" />
                    <TextBlock x:Name="OutputLevelText"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="9" Foreground="#cdd6f4" Text="— dB" />
                </Grid>
            </Border>

            <Border Height="20" Margin="0,6,0,0" BorderBrush="#45475a" BorderThickness="1" CornerRadius="3"
                    Background="#1e1e2e">
                <TextBlock x:Name="ReductionText"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="11" FontWeight="Bold" Foreground="#a6e3a1"
                           Text="— dB réduction" />
            </Border>
        </StackPanel>

        <Button Grid.Row="4"
                Width="100" Height="30"
                Margin="0,5,0,0"
                Click="OnSettingsClick">
            Paramètres
        </Button>
    </Grid>
</Window>
